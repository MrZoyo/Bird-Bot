# 身份组领取和签名功能配置。
# 这里保存角色 ID、按钮选项和签名功能的数值限制；用户可见文案在 bot/locales/zh_CN/role.yaml。
# 用户首次领取任意成就身份组时额外授予的起始成就角色 ID。
achievement_start_role_id: 1145141919810
# 成就身份组领取面板的按钮类别列表。每一项字段：
# name：按钮/面板显示名；
# type：成就类型，必须和 achievements[].type 对应；
# data：历史兼容字段，当前 RoleCog 领取逻辑按 type 查询进度，不直接读取 data。
role_type_name:
- name: 🔴 成就-添加反应
  type: reaction
  data: reaction_count
- name: 🟡 成就-发送消息
  type: message
  data: message_count
- name: 🔵 成就-语音时长
  type: time_spent
  data: time_spent
- name: 🟠 成就-累计签到
  type: checkin_sum
  data: checkin_sum
- name: 🟤 成就-连续签到
  type: checkin_combo
  data: checkin_combo
# 用户选择星座、MBTI 或性别身份组时额外授予的社交起始角色 ID。
social_start_role_id: 1145141919810
# 星座身份组按钮列表；每项 name 是 custom_id，emoji 是按钮显示，role_id 是要授予的角色 ID。
