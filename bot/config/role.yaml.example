# Only data / config fields stay in yaml. All user-visible text (modal
# prompts, success / cooldown / admin messages, etc.) lives under
# `signature:` in bot/locales/<lang>/role.yaml and is resolved via
# bot.utils.i18n.t('role.signature.*').
signature:
