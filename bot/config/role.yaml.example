# Only data / config fields stay in yaml. All user-visible text (modal
# prompts, success / cooldown / admin messages, etc.) lives under
# `signature:` in bot/locales/<lang>/role.yaml and is resolved via
# bot.utils.i18n.t('role.signature.*').
# 签名功能数值配置。用户可见文案在 bot/locales/zh_CN/role.yaml；本地旧 YAML 若残留文案字段，当前代码不会读取。
signature:
# 签名 modal 输入最大长度，传给 discord.ui.TextInput(max_length=...)。
  max_length: 50
# 历史配置字段；当前数据库固定提供 3 个 7 天冷却槽，运行时代码不读取该值。
# P3-10 预备：后续会把签名冷却天数接入配置；普通部署保持默认即可。
  max_changes_per_week: 3
# 设置/查看签名前需要的累计语音时长，单位是分钟；来源是 achievements.time_spent 秒数换算。
  time_requirement: 43200
# 助力用户角色 ID；签名权限说明使用它，PrivateRoom 也用它判断助力加成。
  helper_role_id: 1145141919810
