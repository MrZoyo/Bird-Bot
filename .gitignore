# Configuration and sensitive data
# Real configs live in bot/config/*.yaml; *.yaml.example templates remain tracked.
# Public legacy templates moved to branch legacy-old-files-archive.
bot/config/*.yaml
.local_secrets/
*.pem
*.key
*.env

# Migration tooling products that carry real IDs (see REFACTORING_PLAN.md P1-6 step 0)
tools/migration_db_seed.json
tools/migration_report.md

# Local old_function configs must never return to git with real IDs.
# Sanitized old_function files live on branch legacy-old-files-archive.
old_function/**/*.json
old_function/**/*.yaml

